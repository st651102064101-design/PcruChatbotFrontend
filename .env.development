# Development-only env variables
# Enable visual overlay showing z-index badges when set to "true"
VITE_SHOW_ZINDEX=true

# Axios Request Timeout for development (milliseconds) - same as production
VITE_AXIOS_TIMEOUT=60000

# Typing animation settings for development
VITE_BOT_TYPING_DELAY_MS=12
VITE_BOT_TYPING_INDICATOR_MS=800


