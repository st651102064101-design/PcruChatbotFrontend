# Production environment variables
# These override the base .env file when building for production

# Backend API URL - must point to the actual backend
VITE_API_BASE_URL=https://ict.pcru.ac.th/~s651102064101/backend

# Keep same timeout for production
VITE_AXIOS_TIMEOUT=60000

# App Version
VITE_APP_VERSION=v1.0

# Disable bot auto-open on production
VITE_AUTO_OPEN_CHATBOT=false

# Production-specific settings
VITE_SHOW_ZINDEX=false
